generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}


// ─── Enums ───

enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum UserPlan {
  STANDARD
  VIP
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  BANNED
}

enum CoinTransactionType {
  EARNED
  SPENT
  AUCTION_BID
  AUCTION_REFUND
  ADMIN_ADJUST
}

enum AuctionStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

// ─── Users ───

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  displayName  String
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)
  plan         UserPlan   @default(STANDARD)

  // 2FA (admin only, future)
  totpSecret  String?
  totpEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions         Session[]
  coinBalance      CoinBalance?
  coinTransactions CoinTransaction[]
  watchSessions    WatchSession[]
  auctionBids      AuctionBid[]
  auditLogsActor   AuditLog[]        @relation("AuditActor")
  auditLogsTarget  AuditLog[]        @relation("AuditTarget")

  @@index([email])
  @@index([status])
}

// ─── Sessions ───

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?

  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([refreshToken])
}

// ─── Channels ───

model Channel {
  id          String  @id @default(cuid())
  slug        String  @unique
  displayName String?
  avatarUrl   String?
  isActive    Boolean @default(true)
  addedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watchSessions WatchSession[]
  auctionSlots  AuctionSlot[]
  auctionBids   AuctionBid[]

  @@index([slug])
}

// ─── Watch Sessions ───

model WatchSession {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  startedAt     DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  endedAt       DateTime?

  totalMinutes Int @default(0)
  coinsEarned  Int @default(0)

  @@index([userId, channelId])
  @@index([lastHeartbeat])
}

// ─── Coins ───

model CoinBalance {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance  Int @default(0)
  reserved Int @default(0)

  @@index([userId])
}

model CoinTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         CoinTransactionType
  amount       Int
  balanceAfter Int

  reason   String?
  sourceId String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

// ─── Auctions ───

model Auction {
  id          String @id @default(cuid())
  title       String
  description String?

  status AuctionStatus @default(SCHEDULED)

  minBid       Int @default(10)
  bidIncrement Int @default(5)

  startsAt DateTime
  endsAt   DateTime

  antiSnipingSeconds Int       @default(30)
  extendedEndAt      DateTime?

  highlightDuration Int @default(60)

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bids  AuctionBid[]
  slots AuctionSlot[]

  @@index([status, endsAt])
}

model AuctionBid {
  id        String  @id @default(cuid())
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int
  isWinning Boolean @default(false)
  refunded  Boolean @default(false)
  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([auctionId, amount])
  @@index([userId])
}

model AuctionSlot {
  id        String  @id @default(cuid())
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  startsAt DateTime
  endsAt   DateTime
  isActive Boolean  @default(true)

  @@index([isActive, endsAt])
}

// ─── Audit Log ───

model AuditLog {
  id String @id @default(cuid())

  actorId String
  actor   User   @relation("AuditActor", fields: [actorId], references: [id])

  targetId String?
  target   User?   @relation("AuditTarget", fields: [targetId], references: [id])

  action    String
  details   Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action])
}

// ─── App Config ───

model AppConfig {
  id String @id @default("global")

  coinsPerMinute    Float @default(1)
  vipMultiplier     Float @default(1.5)
  maxDailyCoins     Int   @default(1000)
  heartbeatInterval Int   @default(30)
  heartbeatTimeout  Int   @default(90)

  maxActivePlayers Int @default(20)
  maxChannels      Int @default(100)

  updatedAt DateTime @updatedAt
}
