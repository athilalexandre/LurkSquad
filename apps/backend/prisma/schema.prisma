generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}


// ─── Enums ───

enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum UserPlan {
  STANDARD
  VIP
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  BANNED
  SUSPENDED
}

enum CoinTransactionType {
  EARNED
  SPENT
  AUCTION_BID
  AUCTION_REFUND
  ADMIN_ADJUST
}

enum AuctionStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

// ─── Users ───

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  displayName  String
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)
  plan         UserPlan   @default(STANDARD)

  // 2FA (admin only, future)
  totpSecret  String?
  totpEnabled Boolean @default(false)

  // LurkSquad v4 Fields
  kickSlug         String?     @unique
  channelId        String?     @unique
  channel          Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  flagColor        String      @default("green")
  infractionCount  Int         @default(0)
  suspendedUntil   DateTime?
  lastActiveAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions         Session[]
  coinBalance      CoinBalance?
  coinTransactions CoinTransaction[]
  watchSessions    WatchSession[]
  auctionBids      AuctionBid[]
  auditLogsActor   AuditLog[]        @relation("AuditActor")
  auditLogsTarget  AuditLog[]        @relation("AuditTarget")
  flags            UserFlag[]
  purchases        CoinPurchase[]

  @@index([email])
  @@index([status])
}

// ─── Sessions ───

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?

  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([refreshToken])
}

// ─── Channels ───

model Channel {
  id          String  @id @default(cuid())
  slug        String  @unique
  displayName String?
  avatarUrl   String?
  isActive    Boolean @default(true)
  addedBy     String?

  // LurkSquad v4 Fields
  thumbnailUrl  String?
  viewerCount   Int       @default(0)
  isLive        Boolean   @default(false)
  lastCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watchSessions WatchSession[]
  auctionSlots  AuctionSlot[]
  auctionBids   AuctionBid[]
  owner         User?

  @@index([slug])
}

// ─── Watch Sessions ───

model WatchSession {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  startedAt     DateTime @default(now())
  lastHeartbeat DateTime @default(now())
  endedAt       DateTime?

  totalMinutes Int @default(0)
  coinsEarned  Int @default(0)

  @@index([userId, channelId])
  @@index([lastHeartbeat])
}

// ─── Coins ───

model CoinBalance {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance  Int @default(0)
  reserved Int @default(0)

  @@index([userId])
}

model CoinTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         CoinTransactionType
  amount       Int
  balanceAfter Int

  reason   String?
  sourceId String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

// ─── Auctions ───

model Auction {
  id          String @id @default(cuid())
  title       String
  description String?

  status AuctionStatus @default(SCHEDULED)

  minBid       Int @default(10)
  bidIncrement Int @default(5)

  startsAt DateTime
  endsAt   DateTime

  antiSnipingSeconds Int       @default(30)
  extendedEndAt      DateTime?

  highlightDuration Int @default(60)

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bids  AuctionBid[]
  slots AuctionSlot[]

  // LurkSquad v4 Fields
  isAutomatic Boolean   @default(true)
  revealAt    DateTime  @default(now())
  bidsHidden  Boolean   @default(true)
  slotsCount  Int       @default(5)

  @@index([status, endsAt])
}

model AuctionBid {
  id        String  @id @default(cuid())
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int
  isWinning Boolean @default(false)
  refunded  Boolean @default(false)
  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([auctionId, amount])
  @@index([userId])
}

model AuctionSlot {
  id        String  @id @default(cuid())
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  startsAt DateTime
  endsAt   DateTime
  isActive Boolean  @default(true)

  @@index([isActive, endsAt])
}

// ─── Audit Log ───

model AuditLog {
  id String @id @default(cuid())

  actorId String
  actor   User   @relation("AuditActor", fields: [actorId], references: [id])

  targetId String?
  target   User?   @relation("AuditTarget", fields: [targetId], references: [id])

  action    String
  details   Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action])
}

// ─── App Config ───

model AppConfig {
  id String @id @default("global")

  coinsPerMinute    Float @default(1)
  vipMultiplier     Float @default(1.5)
  maxDailyCoins     Int   @default(1000)
  heartbeatInterval Int   @default(30)
  heartbeatTimeout  Int   @default(90)

  maxActivePlayers Int @default(20)
  maxChannels      Int @default(100)

  updatedAt DateTime @updatedAt

  // LurkSquad v4 Fields - Leilão
  auctionDurationMinutes    Int @default(50)
  auctionRevealMinutes      Int @default(10)
  auctionSlotsCount         Int @default(5)
  auctionMinBid             Int @default(30)
  auctionBidIncrement       Int @default(10)
  auctionAntiSnipeMinutes   Int @default(2)
  auctionAntiSnipeMaxExt    Int @default(3)

  // LurkSquad v4 Fields - Inatividade
  inactivityThresholdHours  Int @default(24)

  // LurkSquad v4 Fields - Loja
  maxPurchasesPerDay        Int @default(2)
  purchaseCooldownMinutes   Int @default(60)
  vipPriceCents             Int @default(2500) // R$ 25,00
  vipDurationDays           Int @default(30)

  // LurkSquad v4 Fields - Kick API
  kickClientId            String?
  kickClientSecret        String?
  channelCheckIntervalSec Int @default(300) // 5 min
}

model UserFlag {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  level          Int       // 1=amarela, 2=laranja, 3=vermelha
  color          String    // "yellow" | "orange" | "red"
  reason         String    // "Inatividade +24h" ou motivo manual
  suspendedUntil DateTime?
  issuedBy       String    // "SYSTEM" ou admin userId
  isActive       Boolean   @default(true)
  removedBy      String?
  removedAt      DateTime?

  createdAt      DateTime  @default(now())

  @@index([userId, isActive])
}

model CoinPackage {
  id         String   @id @default(cuid())
  name       String   // "Starter", "Boost", etc.
  coins      Int      // 200, 500, 1200, 3000
  priceCents Int      // 490, 990, 1990, 3990
  isActive   Boolean  @default(true)
  sortOrder  Int      // 0
  purchases  CoinPurchase[]
  createdAt  DateTime @default(now())
}

model CoinPurchase {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId   String?
  package     CoinPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  type        String   // "COINS" | "VIP"
  coins       Int      // moedas do pacote (0 se VIP)
  priceCents  Int      // valor pago em centavos

  status      String   @default("PENDING") // "PENDING" | "CONFIRMED" | "REJECTED"
  proofUrl    String?  // URL do comprovante (opcional)

  confirmedBy String?  // admin que confirmou
  confirmedAt DateTime?
  rejectedBy  String?  // admin que rejeitou
  rejectedAt  DateTime?

  createdAt   DateTime @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
}

model PixConfig {
  id         String   @id @default("global")
  keyType    String   // "cpf" | "cnpj" | "email" | "phone" | "random"
  keyValue   String   // a chave PIX em si
  holderName String   // nome do titular

  updatedAt  DateTime @updatedAt
}
